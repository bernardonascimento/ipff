# Variáveis de ambiente do site da IPFF.
# Copie este arquivo para `.env.local` e preencha os valores reais.
# Na Vercel, configure as mesmas chaves em Project Settings → Environment Variables.

# ID de medição do Google Analytics 4 (gtag.js). Formato "G-XXXXXXXXXX".
NEXT_PUBLIC_GA_ID=

# ID do container do Google Tag Manager. Formato "GTM-XXXXXXX".
NEXT_PUBLIC_GTM_ID=

# Webhook do Apps Script que grava as inscrições do evento Purples (/purples)
# na planilha do Google. Gere a URL implantando o script como "App da Web".
PURPLES_SHEETS_WEBHOOK_URL=

# E-mail de confirmação da inscrição via Resend (resend.com).
# RESEND_API_KEY: chave em resend.com/api-keys.
# PURPLES_FROM_EMAIL: remetente com domínio verificado no Resend.
RESEND_API_KEY=
PURPLES_FROM_EMAIL="Purples IPFF <eventos@ipff.com.br>"
